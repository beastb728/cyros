#!/bin/sh

TELEMETRY_FILE="/tmp/cyros_telemetry.log"

echo "========================================" >> "$TELEMETRY_FILE"

{
    echo "===== CyrOS Telemetry ====="
    echo "Timestamp: $(date)"
    echo "Kernel: $(uname -r)"
    echo "Architecture: $(uname -m)"
    echo "Hostname: $(hostname)"
    echo "CPU Count: $(nproc)"

    echo "CPU Model:"
    grep "model name" /proc/cpuinfo | head -1

    echo "Memory:"
    grep MemTotal /proc/meminfo

    echo "Load Average:"
    cat /proc/loadavg

    echo "Process Count:"
    ps | wc -l

    echo "Uptime:"
    uptime

    echo
} >> "$TELEMETRY_FILE"
